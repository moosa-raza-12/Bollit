<section class="kv-section kv-contact-hero">
    <div class="kv-custom-container">
        <div class="kv-contact-hero-in">
            {% if section.settings.heading != blank %}
                <h1 class="kv-font-42">{{ section.settings.heading }}</h1>
            {% endif %}
            {% if section.settings.content != blank %}
            <div class="kv-contact-hero-content">{{ section.settings.content }}</div>
            {% endif %}
        </div>
    </div>
</section>

<style>

.kv-contact-hero {
    background-image: url('{{ section.settings.bg_image | image_url: width: master }}');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
}
.kv-contact-hero-in .kv-font-42 {
    text-align: left;
}

.kv-contact-hero-content p {
    color: rgba(31, 31, 31, 0.70);
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 150%;
    margin: 0;
}
.kv-contact-hero-in {
    padding: 12px 0px;
}
@media (max-width: 767.98px) {
  .kv-contact-hero {
      background-image: url('{{ section.settings.bg_image_mobile | image_url: width: master }}');
  }
  .kv-contact-hero-in .kv-font-42 {
    font-size: 30px;
}
.kv-contact-hero-content p {
    font-size: 14px;
}
}
</style>

{% schema %}
{
  "name": "KV Contact Hero",
  "settings": [
   {
      "type": "image_picker",
      "id": "bg_image",
      "label": "BG Desktop",
    },
    {
      "type": "image_picker",
      "id": "bg_image_mobile",
      "label": "BG Mobile",
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
    },
  ],
  "presets": [
    {
      "name": "KV Contact Hero",
    }
  ]
}
{% endschema %}