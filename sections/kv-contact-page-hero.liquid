<section class="kv-section kv-contact-hero">
    <div class="kv-custom-container">
        <div class="kv-contact-hero-in">
            {% if section.settings.heading != blank %}
                <h1>{{ section.settings.heading }}</h1>
            {% endif %}
            {% if section.settings.need_help_content != blank %}
            <div class="kv-need-help-content">{{ section.settings.need_help_content }}</div>
            {% endif %}
        </div>
    </div>
</section>
{% schema %}
{
  "name": "KV Contact Hero",
  "settings": [
   {
      "type": "image_picker",
      "id": "bg_image",
      "label": "BG Desktop",
    },
    {
      "type": "image_picker",
      "id": "bg_image_mobile",
      "label": "BG Mobile",
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
    },
  ],
  "presets": [
    {
      "name": "KV Contact Hero",
    }
  ]
}
{% endschema %}