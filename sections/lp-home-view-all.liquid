{{ 'lp-home-view-all.css' | asset_url | stylesheet_tag }}

<section class="lp-view-all" id="lp-view-all-{{ section.id }}">
  <div class="lp-view-all__container">
    <div class="lp-view-all__header-container">
      <div class="lp-view-all__header">
        {% if section.settings.subtitle != blank %}
          <div class="lp-view-all__subtitle-pill">
            <span class="lp-view-all__subtitle">{{ section.settings.subtitle }}</span>
          </div>
        {% endif %}
        {% if section.settings.title != blank %}
          <h2 class="lp-view-all__title">{{ section.settings.title }}
            <span class="lp-view-all__special-text">{{ section.settings.special_text }}</span>
          </h2>
        {% endif %}
      </div>
      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_link }}" class="lp-view-all__btn lp-view-all__btn--desktop">
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>

    <div class="lp-view-all__grid">
      {% for block in section.blocks limit: 5 %}
        <a
          href="{{ block.settings.link }}"
          class="lp-view-all__card lp-view-all__card--{{ forloop.index }}"
          {{ block.shopify_attributes }}>
          <div class="lp-view-all__card-media">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'lp-view-all__card-img' }}
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'lp-view-all__card-placeholder' }}
            {% endif %}
          </div>
          <div class="lp-view-all__card-overlay">
            <div class="lp-view-all__card-info">
              <span class="lp-view-all__card-title">{{ block.settings.title }}</span>
              <span class="lp-view-all__card-icon">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 16 16"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg">
                  <path
                    d="M6 12L10 8L6 4"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round" />
                </svg>
              </span>
            </div>
          </div>
        </a>
      {% endfor %}
    </div>

    {% if section.settings.button_text != blank %}
      <a href="{{ section.settings.button_link }}" class="lp-view-all__btn lp-view-all__btn--mobile">
        {{ section.settings.button_text }}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
  {
    "name": "LP Home View All",
    "settings": [
      {
        "type": "text",
        "id": "subtitle",
        "label": "Subtitle",
        "default": "Shop by category"
      },
      {
        "type": "text",
        "id": "title",
        "label": "Title",
        "default": "Find what fits"
      },
      {
        "type": "text",
        "id": "special_text",
        "label": "Special Line",
        "default": " your space"
      },
      {
        "type": "text",
        "id": "button_text",
        "label": "Button Text",
        "default": "View All"
      }, {
        "type": "url",
        "id": "button_link",
        "label": "Button Link"
      }
    ],
    "blocks": [
      {
        "type": "category",
        "name": "Category Card",
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Category Image"
          }, {
            "type": "text",
            "id": "title",
            "label": "Category Title"
          }, {
            "type": "url",
            "id": "link",
            "label": "Category Link"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "LP Home View All",
        "blocks": [
          {
            "type": "category",
            "settings": {
              "title": "Tapijtreinigers"
            }
          },
          {
            "type": "category",
            "settings": {
              "title": "HandSteamer"
            }
          },
          {
            "type": "category",
            "settings": {
              "title": "Stoomreiniger"
            }
          },
          {
            "type": "category",
            "settings": {
              "title": "Handheld Steamers"
            }
          }, {
            "type": "category",
            "settings": {
              "title": "Luchtreinigers"
            }
          }
        ]
      }
    ]
  }
{% endschema %}