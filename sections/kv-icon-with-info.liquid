<section class="kv-info-with-icon">
    <div class="kv-custom-container">
        <div class="kv-info-with-icon-in" style="background:{{ section.settings.bg_color }};">

            {% if section.settings.icon != blank %}
                <img 
                    src="{{ section.settings.icon | image_url: width: 200 }}" 
                    alt="" 
                    loading="lazy"
                    >
             {% endif %}
          
            {% if section.settings.content != blank %}
            <div class="kv-info-with-icon-content">{{ section.settings.content }}</div>
            {% endif %}
        </div>
    </div>
</section>
<style>
.kv-info-with-icon-in {
    border-radius: 20px;
    border: 1px solid #3F77A8;
    display: flex;
    padding: 24px;
    align-items: center;
    gap: 24px;
    align-self: stretch;
}
section.kv-info-with-icon {
    padding-top: 20px;
    padding-bottom: 64px;
}
.kv-info-with-icon .kv-custom-container {
    max-width: 840px;
}

.kv-info-with-icon-content p {
    color: rgba(31, 31, 31, 0.90);
    font-size: 18px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    margin: 0;
}
.kv-info-with-icon-content p a {
    color: rgba(31, 31, 31, 0.90);
    font-weight: 600;
    text-decoration: none;
}

@media (max-width: 767.98px) {
}

</style>
{% schema %}
{
  "name": "KV Icon With Info",
  "settings": [
   {
      "type": "color",
      "id": "bg_color",
      "label": "BG Color",
      "default": "#F0F8FF"
    },
    {
      "type": "image_picker",
      "id": "icon",
      "label": "Icon"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
    },
  ],
  "presets": [
    {
      "name": "KV Icon With Info",
    }
  ]
}
{% endschema %}
