<section class="lp-features-bar" id="lp-section-{{ section.id }}">
  <div class="kv-custom-container">
    <div class="lp-features-bar__inner">
      {%- for block in section.blocks -%}
        <div class="lp-feature-items" {{ block.shopify_attributes }}>
