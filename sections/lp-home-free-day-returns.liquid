                      fill="#003665" />
                  </svg>
                {%- when 'truck' -%}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="16"
                    viewBox="0 0 20 16"
                    fill="none">
                    <path d="M4 1C3.4375 1 3 1.46875 3 2V3H7.5C7.75 3 8 3.25 8 3.5C8 3.78125 7.75 4 7.5 4H0.5C0.21875 4 0 3.78125 0 3.5C0 3.25 0.21875 3 0.5 3H2V2C2 0.90625 2.875 0 4 0H11C12.0938 0 13 0.90625 13 2V3H15.0313C15.4688 3 15.875 3.21875 16.1562 3.53125L18.625 6.40625C18.8438 6.6875 19 7.03125 19 7.375V12H19.5C19.75 12 20 12.25 20 12.5C20 12.7812 19.75 13 19.5 13H18C18 14.6563 16.6562 16 15 16C13.3438 16 12 14.6563 12 13H8C8 14.6563 6.65625 16 5 16C3.34375 16 2 14.6563 2 13V9H3V10.7812C3.53125 10.3125 4.21875 10 5 10C6.28125 10 7.40625 10.8438 7.8125 12H12V2C12 1.46875 11.5312 1 11 1H4ZM17.8125 7L15.4063 4.1875C15.3125 4.0625 15.1875 4 15.0313 4H13V7H17.8125ZM13 8V10.7812C13.5313 10.3125 14.2188 10 15 10C16.2812 10 17.4062 10.8438 17.8125 12H18V8H13ZM3 13C3 13.7188 3.375 14.375 4 14.75C4.59375 15.0938 5.375 15.0938 6 14.75C6.59375 14.375 7 13.7188 7 13C7 12.3125 6.59375 11.6562 6 11.2812C5.375 10.9375 4.59375 10.9375 4 11.2812C3.375 11.6562 3 12.3125 3 13ZM15 11C14.2813 11 13.625 11.4062 13.25 12C12.9063 12.625 12.9063 13.4063 13.25 14C13.625 14.625 14.2813 15 15 15C15.6875 15 16.3438 14.625 16.7188 14C17.0625 13.4063 17.0625 12.625 16.7188 12C16.3438 11.4062 15.6875 11 15 11ZM1.5 5H8.5C8.75 5 9 5.25 9 5.5C9 5.78125 8.75 6 8.5 6H1.5C1.21875 6 1 5.78125 1 5.5C1 5.25 1.21875 5 1.5 5ZM0.5 7H7.5C7.75 7 8 7.25 8 7.5C8 7.78125 7.75 8 7.5 8H0.5C0.21875 8 0 7.78125 0 7.5C0 7.25 0.21875 7 0.5 7Z" fill="#003665" />
                  </svg>
              {%- endcase -%}
            {%- endif -%}
          </div>
          <div class="lp-feature-item__content">
            <h3 class="lp-feature-item__title">{{ block.settings.title | escape | newline_to_br }}</h3>
            <p class="lp-feature-item__description">{{ block.settings.description | escape }}</p>
          </div>
        </div>
        {%- unless forloop.last -%}
          <div class="lp-features-bar__separator"></div>
        {%- endunless -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
  {
    "name": "KV Features",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "label": "Background Color",
        "default": "#ffffff"
      }
    ],
    "blocks": [
      {
        "type": "feature",
        "name": "Feature",
        "settings": [
          {
            "type": "select",
            "id": "icon_type",
            "label": "Icon Type",
            "options": [
              {
                "value": "return",
                "label": "Return"
              }, {
                "value": "money",
                "label": "Money Bag"
              }, {
                "value": "truck",
                "label": "Truck"
              }
            ],
            "default": "return"
          }, {
            "type": "html",
            "id": "icon_svg",
            "label": "Custom SVG Icon (Optional)"
          }, {
            "type": "textarea",
            "id": "title",
            "label": "Title",
            "default": "Feature Title"
          }, {
            "type": "textarea",
            "id": "description",
            "label": "Description",
            "default": "Feature description goes here."
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "KV Features",
        "blocks": [
          {
            "type": "feature",
            "settings": {
              "icon_type": "return",
              "title": "Free 30-Day Returns",
              "description": "Return it within 30 days, no hassle."
            }
          }, {
            "type": "feature",
            "settings": {
              "icon_type": "money",
              "title": "100% Money-Back Guarantee",
              "description": "Your purchase is fully protected."
            }
          }, {
            "type": "feature",
            "settings": {
              "icon_type": "truck",
              "title": "Free Shipping",
              "description": "Free delivery on orders above €30."
            }
          }
        ]
      }
    ]
  }
{% endschema %}