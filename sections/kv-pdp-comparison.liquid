<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<section class="kv-section kv-pdp-comp-section" style="background-color: {{ section.settings.background_color }};">
    <div class="kv-custom-container">
        <div class="kv-pdp-comp-header">
            <h2 class="kv-font-42">{{ section.settings.title }}</h2>
            <p class="kv-font-18">{{ section.settings.description }}</p>
        </div>
        <div class="swiper kv-pdp-comp-swiper">
            <div class="swiper-wrapper">
                {% for block in section.blocks %}
                    <div class="swiper-slide">
                        <div class="kv-pdp-comp-grid-item">
                            <div class="kv-pdp-comp-grid-item-image others">
                                <img src="{{ block.settings.image_others | img_url: 'master' }}" alt="">
                                <span class="kv-pdp-comp-grid-others-badge">{{ section.settings.others_title }}</span>
                            </div>
                            <div class="kv-pdp-comp-grid-item-image bollit">
                                <img src="{{ block.settings.image_bollit | img_url: 'master' }}" alt="">
                                <span class="kv-pdp-comp-grid-bollit-badge">
                                    <img src="{{ section.settings.bollit_icon | img_url: '100x100' }}" alt="">
                                </span>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
            <div class="kv-pdp-comp-progressbar-wrap">
                <div class="swiper-pagination kv-pdp-comp-progressbar"></div>
            </div>
        </div>
    </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        new Swiper('.kv-pdp-comp-swiper', {
            slidesPerView: 1.15,
            spaceBetween: 16,
            grabCursor: true,
            pagination: {
                el: '.kv-pdp-comp-progressbar',
                type: 'progressbar',
            },
            breakpoints: {
                0: {
                    slidesPerView: 1,
                    spaceBetween: 12,
                },
                380: {
                    slidesPerView: 1.10,
                    spaceBetween: 12,
                },
                639: {
                    slidesPerView: 1.5,
                    spaceBetween: 12,
                },
                768: {
                    slidesPerView: 2.5,
                    spaceBetween: 16,
                },
                992: {
                    slidesPerView: 3,
                    spaceBetween: 16,
                },
            },
        });
    });
</script>

{% schema %}
{
  "name": "KV PDP Comparison",
  "settings": [
    {
      "type": "textarea",
      "id": "title",
      "label": "Section Title",
      "default": "Your Section Title"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Section Description",
      "default": "Your section description."
    },
    {
      "type": "image_picker",
      "id": "bollit_icon",
      "label": "Bollit Icon"
    },
    {
      "type": "text",
      "id": "others_title",
      "label": "Others Badge Title",
      "default": "Others"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f5f5f5"
    }
  ],
  "blocks": [
    {
      "type": "comparison_item",
      "name": "Comparison Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_others",
          "label": "Item Image Others"
        },
        {
          "type": "image_picker",
          "id": "image_bollit",
          "label": "Item Image Bollit"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "KV PDP Comparison"
    }
  ]
}
{% endschema %}


<style>

.kv-pdp-comp-swiper {
    overflow: hidden;
}

.kv-pdp-comp-header {
    padding: 0 0 64px 0;
}

.kv-pdp-comp-grid-item {
    border-radius: 20px;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr 1fr;
    height: 100%;
}

.kv-pdp-comp-grid-item-image {
    position: relative;
}

.kv-pdp-comp-grid-item-image.others {
    display: flex;
    border-right: 1px solid #E9E9E9;
}

.kv-pdp-comp-grid-others-badge {
    position: absolute;
    border-radius: 18px;
    background: #fff;
    padding: 4px 15px;
    color: #808080;
    font-size: 14px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
}

.kv-pdp-comp-grid-item-image img {
    width: 100%;
    height: 100%;
    display: block;
    max-width: 100%;
    object-fit: cover;
}

.kv-pdp-comp-grid-bollit-badge {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    border-radius: 18px;
    background: #F0F8FF;
    padding: 7px 16px;
    max-height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.kv-pdp-comp-progressbar-wrap {
    margin-top: 64px;
    position: relative;
    height: 3px;
    overflow: hidden;
    border-radius: 16px;
    background: rgba(204, 204, 204, 0.40);
}

.kv-pdp-comp-progressbar-wrap .swiper-pagination-progressbar {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: transparent;
}

.kv-pdp-comp-progressbar-wrap .swiper-pagination-progressbar-fill {
    border-radius: 16px;
    background: #003665;
}

@media (max-width: 1399.98px) {  }


@media (max-width: 1199.98px) {  }


@media (max-width: 991.98px) { 


.swiper.kv-pdp-comp-swiper {
    margin: 0 -20px;
    padding: 0 20px;
}


 }


@media (max-width: 767.98px) { 

    .kv-pdp-comp-header {
    padding: 0 0 36px 0;
}

.kv-pdp-comp-progressbar-wrap {
    margin-top: 36px;
}


 }



@media (max-width: 639.98px) {  }


</style>