{{ 'lp-home-next-day-delivery-ends.css' | asset_url | stylesheet_tag }}
<div class="kv-announcement lp-header" id="lp-section-{{ section.id }}">
  <a href="{{ section.settings.chevron_mobile_link }}">
    <div class="lp-header__top-bar">
      <div class="lp-header__top-container">
        <div class="lp-header__delivery-info">
          <span class="lp-header__icon-truck">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="16" viewBox="0 0 20 16" fill="none">
            <path d="M4 1C3.4375 1 3 1.46875 3 2V3H7.5C7.75 3 8 3.25 8 3.5C8 3.78125 7.75 4 7.5 4H0.5C0.21875 4 0 3.78125 0 3.5C0 3.25 0.21875 3 0.5 3H2V2C2 0.90625 2.875 0 4 0H11C12.0938 0 13 0.90625 13 2V3H15.0313C15.4688 3 15.875 3.21875 16.1562 3.53125L18.625 6.40625C18.8438 6.6875 19 7.03125 19 7.375V12H19.5C19.75 12 20 12.25 20 12.5C20 12.7812 19.75 13 19.5 13H18C18 14.6563 16.6562 16 15 16C13.3438 16 12 14.6563 12 13H8C8 14.6563 6.65625 16 5 16C3.34375 16 2 14.6563 2 13V9H3V10.7812C3.53125 10.3125 4.21875 10 5 10C6.28125 10 7.40625 10.8438 7.8125 12H12V2C12 1.46875 11.5312 1 11 1H4ZM17.8125 7L15.4063 4.1875C15.3125 4.0625 15.1875 4 15.0313 4H13V7H17.8125ZM13 8V10.7812C13.5313 10.3125 14.2188 10 15 10C16.2812 10 17.4062 10.8438 17.8125 12H18V8H13ZM3 13C3 13.7188 3.375 14.375 4 14.75C4.59375 15.0938 5.375 15.0938 6 14.75C6.59375 14.375 7 13.7188 7 13C7 12.3125 6.59375 11.6562 6 11.2812C5.375 10.9375 4.59375 10.9375 4 11.2812C3.375 11.6562 3 12.3125 3 13ZM15 11C14.2813 11 13.625 11.4062 13.25 12C12.9063 12.625 12.9063 13.4063 13.25 14C13.625 14.625 14.2813 15 15 15C15.6875 15 16.3438 14.625 16.7188 14C17.0625 13.4063 17.0625 12.625 16.7188 12C16.3438 11.4062 15.6875 11 15 11ZM1.5 5H8.5C8.75 5 9 5.25 9 5.5C9 5.78125 8.75 6 8.5 6H1.5C1.21875 6 1 5.78125 1 5.5C1 5.25 1.21875 5 1.5 5ZM0.5 7H7.5C7.75 7 8 7.25 8 7.5C8 7.78125 7.75 8 7.5 8H0.5C0.21875 8 0 7.78125 0 7.5C0 7.25 0.21875 7 0.5 7Z" fill="white"/>
          </svg>
          </span>
          <div class="lp-header__countdown">
            <span class="lp-header__countdown-text">{{ section.settings.countdown_text }}</span>
            <div class="lp-header__timer" data-timer="{{ section.settings.countdown_end_time }}">
              <div class="lp-header__timer-box">
                <span class="lp-header__timer-num" data-hours>07</span>
                <span class="lp-header__timer-unit">HRS</span>
              </div>
              <div class="lp-header__timer-box">
                <span class="lp-header__timer-num" data-minutes>59</span>
                <span class="lp-header__timer-unit">MINS</span>
              </div>
              <div class="lp-header__timer-box">
                <span class="lp-header__timer-num" data-seconds>12</span>
                <span class="lp-header__timer-unit">SEC</span>
              </div>
            </div>
          </div>
          {% if section.settings.chevron_mobile_link != blank %}
          <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 8 8" fill="none">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M1 2H3.5V3H1V7H5V4.5H6V7C6 7.26522 5.89464 7.51957 5.70711 7.70711C5.51957 7.89464 5.26522 8 5 8H1C0.734784 8 0.48043 7.89464 0.292893 7.70711C0.105357 7.51957 0 7.26522 0 7V3C0 2.73478 0.105357 2.48043 0.292893 2.29289C0.48043 2.10536 0.734784 2 1 2ZM6.307 1H4V0H8V4H7V1.721L4.332 4.389L3.625 3.682L6.307 1Z" fill="white"/>
          </svg>
          {% endif %}
        </div>
      </div>
    </div>
  </a>
</div>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const timer = document.querySelector('#lp-section-{{ section.id }} [data-timer]');
    if (!timer) return;
    const endTime = new Date();
    endTime.setHours(23, 59, 59); // Logic: ends at end of day, or use schema input
    function updateTimer() {
      const now = new Date().getTime();
      const distance = endTime - now;
      if (distance < 0) return;
      const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((distance % (1000 * 60)) / 1000);
      timer.querySelector('[data-hours]').innerText = hours.toString().padStart(2, '0');
      timer.querySelector('[data-minutes]').innerText = minutes.toString().padStart(2, '0');
      timer.querySelector('[data-seconds]').innerText = seconds.toString().padStart(2, '0');
    }
    setInterval(updateTimer, 1000);
    updateTimer();
  });
</script>
{% schema %}
{
  "name": "LP Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "icon",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "countdown_text",
      "label": "Countdown Text",
      "default": "Next-day delivery ends in"
    },
    {
      "type": "url",
      "id": "chevron_mobile_link",
      "label": "Link"
    },
  
  ],
  "blocks": [
    {
      "type": "nav_item",
      "name": "Navigation Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Link Text"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link URL"
        },
        {
          "type": "checkbox",
          "id": "has_dropdown",
          "label": "Show Dropdown Icon",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP Header",
      "blocks": [
        { "type": "nav_item", "settings": { "text": "Shop by category", "url": "#", "has_dropdown": true } },
        { "type": "nav_item", "settings": { "text": "Best sellers", "url": "#", "has_dropdown": true } },
        { "type": "nav_item", "settings": { "text": "Collection", "url": "#" } },
        { "type": "nav_item", "settings": { "text": "Track your order", "url": "#" } },
        { "type": "nav_item", "settings": { "text": "Company", "url": "#", "has_dropdown": true } }
      ]
    }
  ]
}
{% endschema %}