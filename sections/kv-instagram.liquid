<style>
  .kv-instagram {
    padding: 56px 0;
    background: #f4f5f7;
  }

  .kv-instagram-wrap {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 38px;
    align-items: center;
  }

  .kv-instagram-content {
    max-width: 430px;
  }

  .kv-instagram-label {
    display: inline-block;
    padding: 4px 10px;
    margin-bottom: 10px;
    border-left: 2px solid #d8b178;
    border-right: 2px solid #d8b178;
    color: #8a6233;
    font-size: 19px;
    font-style: italic;
    line-height: 1.1;
  }

  .kv-instagram-title {
    margin: 0 0 24px;
    color: #1f2329;
    font-size: 56px;
    font-weight: 500;
    line-height: 1.05;
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .kv-instagram-title em {
    color: #0f4f85;
    font-style: italic;
    font-weight: 400;
  }

  .kv-instagram-title-text {
    display: inline-block;
  }

  .kv-instagram-icon {
    width: 32px;
    height: 32px;
    margin-top: 10px;
    flex: 0 0 32px;
  }

  .kv-instagram-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 380px;
    min-height: 66px;
    border-radius: 999px;
    border: 1px solid #0d4a82;
    background: #07467e;
    color: #fff;
    font-size: 25px;
    font-weight: 500;
    line-height: 1;
    text-decoration: none;
    transition: background 0.25s ease;
  }

  .kv-instagram-btn:hover {
    background: #083a67;
  }

  .kv-instagram-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
    grid-template-areas:
      "a b"
      "a c"
      "d e";
  }

  .kv-instagram-item {
    display: block;
    overflow: hidden;
    border-radius: 20px;
    min-height: 140px;
  }

  .kv-instagram-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .kv-instagram-item:nth-child(1) { grid-area: a; min-height: 392px; }
  .kv-instagram-item:nth-child(2) { grid-area: b; min-height: 190px; }
  .kv-instagram-item:nth-child(3) { grid-area: c; min-height: 194px; }
  .kv-instagram-item:nth-child(4) { grid-area: d; min-height: 190px; }
  .kv-instagram-item:nth-child(5) { grid-area: e; min-height: 190px; }
.kv-instagram-content.kv-section-head {
    justify-content: flex-start;
    text-align: left;
    align-items: flex-start;
}
.kv-instagram-heading {
    display: flex;
    align-items: center;
    gap: 20px;
}
.kv-instagram-heading {
    padding-bottom: 22px;
}
.kv-instagram" a.kv-blue-btn {
    font-size: 18px;
}
.kv-instagram-content.kv-section-head .kv-font-38 em {
    display: block;
}
.kv-instagram-content.kv-section-head .kv-font-38 {
    text-align: left;
}

  @media (max-width: 991px) {
    .kv-instagram-wrap {
      grid-template-columns: 1fr;
      gap: 26px;
    }

    .kv-instagram-content {
      max-width: 100%;
      text-align: center;
    }

    .kv-instagram-title {
      justify-content: center;
    }

    .kv-instagram-btn {
      min-width: 300px;
      min-height: 56px;
      font-size: 21px;
    }
  }

  @media (max-width: 767px) {
    .kv-instagram {
      padding: 44px 0;
    }

    .kv-instagram-label {
      font-size: 14px;
    }

    .kv-instagram-title {
      font-size: 38px;
      margin-bottom: 18px;
      gap: 8px;
    }

    .kv-instagram-icon {
      width: 24px;
      height: 24px;
      margin-top: 8px;
      flex-basis: 24px;
    }

    .kv-instagram-btn {
      min-width: 100%;
      width: 100%;
      max-width: 360px;
      min-height: 50px;
      font-size: 18px;
    }

    .kv-instagram-grid {
      gap: 6px;
    }

    .kv-instagram-item {
      border-radius: 12px;
    }

    .kv-instagram-item:nth-child(1) { min-height: 270px; }
    .kv-instagram-item:nth-child(2),
    .kv-instagram-item:nth-child(3),
    .kv-instagram-item:nth-child(4),
    .kv-instagram-item:nth-child(5) { min-height: 132px; }
  }
</style>

