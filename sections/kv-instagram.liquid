                </svg>
          <h2 class="kv-font-38">
           
            {{ section.settings.heading }}
          </h2>
        </div>
        {% endif %}

        {% if section.settings.button_text != blank and section.settings.button_url != blank %}
          <a class="kv-blue-btn" href="{{ section.settings.button_url }}">{{ section.settings.button_text }}</a>
        {% endif %}
      </div>

      <div class="kv-instagram-grid">
        {% for block in section.blocks limit: 5 %}
          {% if block.settings.image != blank %}
            {% if block.settings.link != blank %}
              <a class="kv-instagram-item" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>
                {{
                  block.settings.image
                  | image_url: width: master
                  | image_tag:
                    alt: block.settings.image.alt
                }}
              </a>
            {% else %}
              <div class="kv-instagram-item" {{ block.shopify_attributes }}>
                {{
                  block.settings.image
                  | image_url: width: master
                  | image_tag:
                    alt: block.settings.image.alt
                }}
              </div>
            {% endif %}
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "KV Instagram",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Top label",
      "default": "Join our community"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Follow us on <em>Instagram</em>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Follow @bollitclean"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Instagram image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "KV Instagram",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
