                    <stop offset="1" stop-color="#5C6CB3"/>
                    </radialGradient>
                    <radialGradient id="paint2_radial_23025_17436" cx="0" cy="0" r="1" gradientUnits="userSpaceOnUse" gradientTransform="translate(23.7328 9.36402) scale(3.87425)">
                    <stop stop-color="#5F6DB3"/>
