<section class="kv-need-help-section">
    <div class="kv-need-help-in" style="background:{{ section.settings.bg_color }};">
        {% if section.settings.need_help_heading != blank %}
            <h5>{{ section.settings.need_help_heading }}</h5>
        {% endif %}
        {% if section.settings.need_help_content != blank %}
         <div class="kv-need-help-content">{{ section.settings.need_help_content }}</div>
        {% endif %}
    </div>
</section>
<style>
.kv-section.kv-faq-page {
    padding-bottom: 42px;
}
.kv-need-help-in {
    border-radius: 20px;
    border: 1px solid #3F77A8;
    display: flex;
    padding: 24px;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 12px;
    max-width: 800px;
    margin: 0 auto;
}
.kv-need-help-in h5 {
    color: #1F1F1F;
    font-size: 22px;
    font-style: normal;
    font-weight: 500;
    line-height: 150%;
    margin: 0;
    text-align: left;
    display: block;
    width: 100%;
}

.kv-need-help-content p {
    color: rgba(31, 31, 31, 0.70);
    font-size: 18px;
    font-style: normal;
    font-weight: 400;
    line-height: 150%;
    margin: 0;
}
.kv-need-help-content p strong{
    color: #1F1F1F;
    font-weight: 500;
}
</style>
{% schema %}
{
  "name": "KV Need More Help",
  "settings": [
   {
      "type": "color",
      "id": "bg_color",
      "label": "BG Color",
      "default": "#F0F8FF"
    },
    {
      "type": "text",
      "id": "need_help_heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "need_help_content",
      "label": "Content",
    },
  ],
  "presets": [
    {
      "name": "KV Need More Help",
    }
  ]
}
{% endschema %}
