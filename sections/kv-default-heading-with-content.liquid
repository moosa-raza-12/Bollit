<section class="kv-default-heading-with-content">
  <div class="kv-custom-container">
    <div class="kv-default-heading-with-content-in" style="background:{{ section.settings.bg_color }};">
      {% if section.settings.heading != blank %}
        <h4 class="kv-default-heading-with-content-title">{{ section.settings.heading }}</h4>
      {% endif %}

      <div class="kv-default-heading-with-content-grid{% if section.settings.enable_second_content %} kv-default-heading-with-content-grid--two{% endif %}">
        {% if section.settings.content != blank %}
          <div class="kv-default-heading-with-content-info">
            {{ section.settings.content }}
          </div>
        {% endif %}

        {% if section.settings.enable_second_content and section.settings.content_2 != blank %}
          <div class="kv-default-heading-with-content-info">
            {{ section.settings.content_2 }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>
<style>
.kv-default-heading-with-content-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 20px;
}

.kv-default-heading-with-content-grid--two {
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 28px;
}

@media (max-width: 767.98px) {
  .kv-default-heading-with-content-grid--two {
    grid-template-columns: 1fr;
    gap: 18px;
  }
}
</style>
{% schema %}
{
  "name": "KV Heading With Content",
  "settings": [
   {
      "type": "color",
      "id": "bg_color",
      "label": "BG Color",
      "default": "#F0F8FF"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
    },
    {
      "type": "checkbox",
      "id": "enable_second_content",
      "label": "Enable second rich text",
      "default": false
    },
    {
      "type": "richtext",
      "id": "content_2",
      "label": "Content 2"
    },
  ],
  "presets": [
    {
      "name": "KV Heading With Content",
    }
  ]
}
{% endschema %}
