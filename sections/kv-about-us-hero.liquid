<style>
  .kv-about-hero {
    min-height: 465px;
    display: flex;
    align-items: center;
    overflow: hidden;
    background-size: cover;
    background-position: center right;
    background-repeat: no-repeat;
    border-radius: 0;
  }



  .kv-about-hero .kv-custom-container {
    width: 100%;
  }

  .kv-about-hero-in {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    max-width: 478px;
  }

 

  .kv-contact-hero-content {
    margin-bottom: 24px;
  }
  .kv-contact-hero-content p {
    color: #FFF;
    font-size: 18px;
    font-style: normal;
    font-weight: 400;
    line-height: 150%;
    margin: 0;
}
.kv-about-hero-top .kv-font-44 {
    color: #fff;
    text-align: left;
}
.kv-about-hero-top .kv-font-44 em{
    color: #C4E3FF;
}
 
  @media (max-width: 767px) {
    .kv-about-hero {
        min-height: 430px;
        background-position: center;
    }



    .kv-about-hero-in {
        max-width: 100%;
    }

    .kv-about-hero-title {
        font-size: 34px;
        margin-bottom: 12px;
    }

    .kv-section.kv-about-hero {
      padding: 20px 0px;
    }
    .kv-contact-hero-content p {
     font-size: 14px;
    }

    .kv-about-hero-in .kv-blue-btn {
     font-size: 18px;
    }

    .kv-about-hero {
        align-items: stretch;
    }
    .kv-about-hero .kv-custom-container {
        display: flex;
        height: 100%;
    }
    .kv-about-hero-in {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%; 
    }
  }
</style>

{% liquid
  assign hero_bg = section.settings.bg_image | image_url: width: 2400
  assign hero_bg_mobile = section.settings.bg_image_mobile | image_url: width: 1200
%}

<section
  class="kv-section kv-about-hero"
  style="background-image: url('{% if section.settings.bg_image != blank %}{{ hero_bg }}{% endif %}');"
>
  <div class="kv-custom-container">
    <div class="kv-about-hero-in">
        <div class="kv-about-hero-top">
        {% if section.settings.heading != blank %}
            <h1 class="kv-font-44">{{ section.settings.heading }}</h1>
        {% endif %}
        {% if section.settings.content != blank %}
            <div class="kv-contact-hero-content">{{ section.settings.content }}</div>
        {% endif %}
       </div>
      {% if section.settings.btn_text != blank and section.settings.btn_url != blank %}
        <a class="kv-blue-btn" href="{{ section.settings.btn_url }}">{{ section.settings.btn_text }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% if section.settings.bg_image_mobile != blank %}
  <style>
    @media (max-width: 767px) {
      .kv-about-hero {
        background-image: url('{{ hero_bg_mobile }}') !important;
      }
    }
  </style>
{% endif %}

{% schema %}
{
  "name": "KV About Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "BG Desktop"
    },
    {
      "type": "image_picker",
      "id": "bg_image_mobile",
      "label": "BG Mobile"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button text"
    },
    {
      "type": "text",
      "id": "btn_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "KV About Hero"
    }
  ]
}
{% endschema %}