<section class="kv-section kv-features-grid-section" style="background-color: {{ section.settings.background_color }};">
    <div class="kv-custom-container">
        <div class="kv-features-grid-header">
            <h2 class="kv-font-42">{{ section.settings.title }}</h2>
            <p class="kv-font-18">{{ section.settings.description }}</p>
        </div>
        <div class="kv-features-grid-grid">
            {% for block in section.blocks %}
                <div class="kv-features-grid-item">
                    <div class="kv-features-grid-item-image">
                        {% if block.settings.image != blank %}
                            <img src="{{ block.settings.image | img_url: '400x400' }}" alt="{{ block.settings.feature_title | escape }}">
                        {% endif %}
                    </div>
                    <div class="kv-features-grid-item-content">
                        {% if block.settings.feature_title != blank %}
                            <span class="kv-features-grid-item-title">{{ block.settings.feature_title }}</span>
                        {% endif %}
                        {% if block.settings.feature_description != blank %}
                            <span class="kv-features-grid-item-description">{{ block.settings.feature_description }}</span>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
</section>

{% schema %}
{
  "name": "KV PDP Features Grid",
  "settings": [
    {
      "type": "textarea",
      "id": "title",
      "label": "Section Title",
      "default": "Your Section Title"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Section Description",
      "default": "Your section description."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f5f5f5"
    }
  ],
  "blocks": [
    {
      "type": "feature_item",
      "name": "Feature Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Feature Image"
        },
        {
          "type": "text",
          "id": "feature_title",
          "label": "Feature Title",
          "default": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "feature_description",
          "label": "Feature Description",
          "default": "Feature description."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "KV PDP Features Grid"
    }
  ]
}
{% endschema %}

<style>
.kv-features-grid-header {
    padding: 0 0 64px 0;
}

.kv-features-grid-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
}

.kv-features-grid-item {
    background: #fff;
    border-radius: 18px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    padding: 32px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
}

.kv-features-grid-item-image {
    width: 120px;
    height: 120px;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 12px;
    background: #F5F7FA;
}

.kv-features-grid-item-image img {
    display: block;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
}

.kv-features-grid-item-title {
    display: block;
    font-size: 20px;
    font-weight: 700;
    color: #003665;
    margin-bottom: 10px;
    text-align: center;
}

.kv-features-grid-item-description {
    display: block;
    font-size: 16px;
    color: #333;
    text-align: center;
}

/* Responsive adjustments */
@media (max-width: 991.98px) {
    .kv-features-grid-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 24px;
    }
}

@media (max-width: 767.98px) {
    .kv-features-grid-header {
        padding: 0 0 36px 0;
    }
    .kv-features-grid-grid {
        grid-template-columns: 1fr;
        gap: 20px;
    }
    .kv-features-grid-item {
        padding: 24px 12px;
    }
}
</style>