<section class="kv-section kv-features-grid-section" style="background-color: {{ section.settings.background_color }};">
    <div class="kv-custom-container">
        <div class="kv-features-grid-header">
            <h2 class="kv-font-42">{{ section.settings.title }}</h2>
            <p class="kv-font-18">{{ section.settings.description }}</p>
        </div>
        <div class="kv-features-grid-grid">
            {% for block in section.blocks %}
                <div class="kv-features-grid-item">
                    <div class="kv-features-grid-item-image">
                        {% if block.settings.image != blank %}
                            <img src="{{ block.settings.image | img_url: '400x400' }}" alt="{{ block.settings.feature_title | escape }}">
                        {% endif %}
                    </div>
                    <div class="kv-features-grid-item-content">
                        {% if block.settings.feature_title != blank %}
                            <h3 class="kv-features-grid-item-title">{{ block.settings.feature_title }}</h3>
                        {% endif %}
                        {% if block.settings.feature_description != blank %}
                            <p class="kv-features-grid-item-description">{{ block.settings.feature_description }}</p>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
</section>

{% schema %}
{
  "name": "KV PDP Features Grid",
  "settings": [
    {
      "type": "textarea",
      "id": "title",
      "label": "Section Title",
      "default": "Your Section Title"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Section Description",
      "default": "Your section description."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f5f5f5"
    }
  ],
  "blocks": [
    {
      "type": "feature_item",
      "name": "Feature Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Feature Image"
        },
        {
          "type": "text",
          "id": "feature_title",
          "label": "Feature Title",
          "default": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "feature_description",
          "label": "Feature Description",
          "default": "Feature description."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "KV PDP Features Grid"
    }
  ]
}
{% endschema %}

<style>
.kv-features-grid-header {
    padding: 0 0 64px 0;
}

.kv-features-grid-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
}

.kv-features-grid-item {
    border-radius: 20px;
    border: 1px solid #E1ECF5;
    background: #FFF;
    padding: 16px;
}

.kv-features-grid-item-image {
    display: flex;
    border-radius: 18px;
    background: linear-gradient(180deg, #F1F8FF 0%, #F7F7F7 100%);
    overflow: hidden;
}

.kv-features-grid-item-image img {
    display: flex;
    width: 100%;
    max-width: 100%;
    height: 100%;
}

.kv-features-grid-item-content {
    padding: 16px 0 0 0;
}

.kv-features-grid-item-title {
    color: #003665;
    font-size: 26px;
    font-style: normal;
    font-weight: 500;
    line-height: 1.11;
    letter-spacing: -0.26px;
    margin: 0;
}

.kv-features-grid-item-description {
    color: rgba(31, 31, 31, 0.70);
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 150%;
    margin: 0;
}

@media (max-width: 1199.98px) {

.kv-features-grid-grid {
    grid-template-columns: repeat(3, 1fr);
}

}

@media (max-width: 991.98px) {
    .kv-features-grid-item-title {
    font-size: 24px;
    line-height: normal;
}


}

@media (max-width: 767.98px) {

    .kv-features-grid-header {
    padding: 0px 0 36px 0;
}

.kv-features-grid-grid {
    grid-template-columns: repeat(2, 1fr);
}


}

@media (max-width: 639px) {

    .kv-features-grid-header .kv-font-42 {
    margin: 0 0 12px;
    line-height: 1.4;
}

.kv-features-grid-header .kv-font-42 em {
    display: block;
}


}

@media (max-width: 575.98px) {

    .kv-features-grid-grid {
    grid-template-columns: 1fr;
}


}

</style>