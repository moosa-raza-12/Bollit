      </g>
    </svg>
    </div>
  {%- endif -%}
</footer>

{% schema %}
{
  "name": "Quick Links Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Bollit builds powerful, chemical-free cleaning systems made for real homes. Designed for performance."
    },
    {
      "type": "text",
      "id": "newsletter_title",
      "label": "Newsletter Title",
      "default": "get 10% off"
    },
    {
      "type": "text",
      "id": "newsletter_desc",
      "label": "Newsletter Description",
      "default": "Sign up for expert advice on cleaning, healthy home"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email Placeholder",
      "default": "E-mail"
    },
    {
      "type": "text",
      "id": "subscribe_button_text",
      "label": "Button Text",
      "default": "Subscribe"
    },
    {
      "type": "url",
      "id": "terms_url",
      "label": "Terms of Service Link"
    },
    {
      "type": "url",
      "id": "privacy_url",
      "label": "Privacy Policy Link"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "Bollit."
    },
    {
      "type": "checkbox",
      "id": "show_background_graphic",
      "label": "Show Background Graphic",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Link Column",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Column Title"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        },
        {
          "type": "textarea",
          "id": "custom_content",
          "label": "Custom Content (e.g. Email)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Quick Links Footer",
      "blocks": [
        {
          "type": "column",
          "settings": {
            "title": "Products"
          }
        },
        {
          "type": "column",
          "settings": {
            "title": "Quick Links"
          }
        },
        {
          "type": "column",
          "settings": {
            "title": "Contact",
            "custom_content": "helpbollit@gmail.com"
          }
        }
      ]
    }
  ]
}
{% endschema %}