<section class="kv-section kv-pdp-ft-section" style="background-color: {{ section.settings.background_color }};">
    <div class="kv-custom-container">
        <div class="kv-pdp-ft-header">
            <h2 class="kv-font-42">{{ section.settings.title }}</h2>
            <p class="kv-font-18">{{ section.settings.description }}</p>
        </div>

        {% assign tabs_string = "" %}
        {% for block in section.blocks %}
            {% assign tab_name = block.settings.tab_name | strip %}
            {% assign check_str = tabs_string | prepend: "|||" | append: "|||" %}
            {% assign tab_match = tab_name | prepend: "|||" | append: "|||" %}
            {% unless check_str contains tab_match %}
                {% if tabs_string != "" %}
                    {% assign tabs_string = tabs_string | append: "|||" %}
                {% endif %}
                {% assign tabs_string = tabs_string | append: tab_name %}
            {% endunless %}
        {% endfor %}
        {% assign tab_list = tabs_string | split: "|||" %}

        <div class="kv-pdp-ft-tabs-row">
            <div class="kv-pdp-ft-tabs">
                {% for tab in tab_list %}
                    <button class="kv-pdp-ft-tab{% if forloop.first %} active{% endif %}" data-tab="{{ tab | handleize }}">
                        {{ tab }}
                    </button>
                {% endfor %}
            </div>

        </div>

        {% for tab in tab_list %}
            <div class="kv-pdp-ft-swiper-wrap" data-tab-content="{{ tab | handleize }}" {% unless forloop.first %}style="display:none;"{% endunless %}>
                <div class="swiper kv-pdp-ft-swiper">
                    <div class="swiper-wrapper">
                        {% for block in section.blocks %}
                            {% assign block_tab = block.settings.tab_name | strip %}
                            {% if block_tab == tab %}
                                <div class="swiper-slide">
                                    <div class="kv-pdp-ft-card">
                                        <div class="kv-pdp-ft-card-image">
                                            <img src="{{ block.settings.image | img_url: '600x600' }}" alt="{{ block.settings.title }}">
                                            <div class="kv-pdp-ft-card-content">
                                                <div class="kv-pdp-ft-card-title-row">
                                                    {% if block.settings.quantity != blank %}
                                                        <span class="kv-pdp-ft-card-qty">{{ block.settings.quantity }}</span>
                                                    {% endif %}
                                                    <span class="kv-pdp-ft-card-title">{{ block.settings.title }}</span>
                                                </div>
                                                {% if block.settings.description != blank %}
                                                    <p class="kv-pdp-ft-card-desc">{{ block.settings.description }}</p>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                    <div class="kv-pdp-ft-progressbar-wrap">
                        <div class="swiper-pagination kv-pdp-ft-progressbar"></div>
                    </div>
                    
                    
                </div>
            </div>
        {% endfor %}
    </div>
</section>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var section = document.querySelector('.kv-pdp-ft-section');
        if (!section) return;

        var tabs = section.querySelectorAll('.kv-pdp-ft-tab');
        var swiperInstances = {};

        var swiperConfig = {
            slidesPerView: 1.15,
            spaceBetween: 16,
            grabCursor: true,
            breakpoints: {
                0: {
                    slidesPerView: 1,
                    spaceBetween: 12,
                },
                380: {
                    slidesPerView: 1.28,
                    spaceBetween: 12,
                },
                479: {
                    slidesPerView: 1.5,
                    spaceBetween: 12,
                },
                639: {
                    slidesPerView: 2,
                    spaceBetween: 12,
                },
                768: {
                    slidesPerView: 2.3,
                    spaceBetween: 16,
                },
                992: {
                    slidesPerView: 3,
                    spaceBetween: 16,
                },
                1399.98: {
                    slidesPerView: 3,
                    spaceBetween: 16,
                },
            },
        };

        function initSwiper(tabId) {
            if (swiperInstances[tabId]) {
                swiperInstances[tabId].update();
                return;
            }
            var wrap = section.querySelector('[data-tab-content="' + tabId + '"]');
            if (!wrap) return;

            var config = Object.assign({}, swiperConfig, {
                pagination: {
                    el: wrap.querySelector('.kv-pdp-ft-progressbar'),
                    type: 'progressbar'
                }
            });
            swiperInstances[tabId] = new Swiper(wrap.querySelector('.kv-pdp-ft-swiper'), config);
        }

        var firstTabId = tabs[0] ? tabs[0].getAttribute('data-tab') : null;
        if (firstTabId) initSwiper(firstTabId);

        tabs.forEach(function (tab) {
            tab.addEventListener('click', function () {
                var tabId = this.getAttribute('data-tab');

                tabs.forEach(function (t) { t.classList.remove('active'); });
                this.classList.add('active');

                section.querySelectorAll('.kv-pdp-ft-swiper-wrap').forEach(function (w) {
                    w.style.display = 'none';
                });

                var activeWrap = section.querySelector('[data-tab-content="' + tabId + '"]');
                if (activeWrap) {
                    activeWrap.style.display = 'block';
                    initSwiper(tabId);
                }
            });
        });
    });
</script>

{% schema %}
{
  "name": "KV PDP Features Tab",
  "settings": [
    {
      "type": "textarea",
      "id": "title",
      "label": "Section Title",
      "default": "What's in the box?"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Section Description",
      "default": "Everything you need for deep, effortless cleaning."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f5f5f5"
    }
  ],
  "blocks": [
    {
      "type": "feature_slide",
      "name": "Feature Slide",
      "settings": [
        {
          "type": "text",
          "id": "tab_name",
          "label": "Tab Name",
          "info": "Slides with the same tab name are grouped under one tab.",
          "default": "Tab Name"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Slide Image"
        },
        {
          "type": "text",
          "id": "quantity",
          "label": "Quantity Badge",
          "info": "e.g. 2x, 1x",
          "default": "1x"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Slide Title",
          "default": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Slide Description",
          "default": "Feature description."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "KV PDP Features Tab"
    }
  ]
}
{% endschema %}


<style>
.kv-pdp-ft-section {
    overflow: hidden;
}

.kv-pdp-ft-header {
    padding: 0 0 64px 0;
}

.kv-pdp-ft-tabs-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 64px;
    flex-wrap: wrap;
}

.kv-pdp-ft-tabs {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
}

.kv-pdp-ft-tab {
    background: none;
    border: none;
    padding: 12px;
    cursor: pointer;
    transition: color 0.25s, border-color 0.25s;
    white-space: nowrap;
    color: #808080;
    font-size: 18px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
    border-radius: 8px 8px 0 0;
    border-bottom: 1px solid transparent;
}

.kv-pdp-ft-tab.active {
    border-radius: 8px 8px 0 0;
    border-bottom: 1px solid #003665;
    background: #F0F8FF;
    color: #003665;
}
.kv-pdp-ft-cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 32px;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.25s;
    flex-shrink: 0;
    border-radius: 100px;
    background: #003665;
    color: #FFF;
    text-align: center;
    font-size: 16px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
}

.kv-pdp-ft-cta-badge {
    padding: 8px;
    border-radius: 100px;
    background: #034884;
    color: #FFF;
    font-size: 14px;
    font-style: normal;
    font-weight: 500;
    line-height: 12px;
}

.kv-pdp-ft-swiper {
    overflow: visible;
}

.kv-pdp-ft-card {
    overflow: hidden;
    background: #fff;
    height: 100%;
    display: flex;
    flex-direction: column;
    border-radius: 20px;
    position: relative;
}

.kv-pdp-ft-card-image {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
}

.kv-pdp-ft-card-image img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    max-width: 100%;
}

.kv-pdp-ft-card-content {
    padding: 8px 12px;
    position: absolute;
    left: 12px;
    bottom: 12px;
    width: calc(100% - 48px);
    max-width: 100%;
    right: 12px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.50);
    backdrop-filter: blur(8px);
}

.kv-pdp-ft-card-title-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 2px;
}

.kv-pdp-ft-card-qty {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    border-radius: 100px;
    background: #F0F8FF;
    width: 32px;
    height: 32px;
    white-space: nowrap;
    max-width: 32px;
    min-width: 32px;
    color: #003665;
    font-size: 20px;
    font-style: normal;
    font-weight: 500;
    line-height: unset;
    letter-spacing: 0;
}

.kv-pdp-ft-card-title {
    font-size: 20px;
    margin: 0;
    color: #003665;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
}
.kv-pdp-ft-card-desc {
    color: rgba(31, 31, 31, 0.70);
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
}

.kv-pdp-ft-progressbar-wrap {
    margin-top: 64px;
    position: relative;
    height: 3px;
    overflow: hidden;
    border-radius: 16px;
    background: rgba(204, 204, 204, 0.40);
}

.kv-pdp-ft-progressbar-wrap .swiper-pagination-progressbar {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: transparent;
}

.kv-pdp-ft-progressbar-wrap .swiper-pagination-progressbar-fill {
    border-radius: 16px;
    background: #003665;
}

@media (max-width: 1399.98px) {
    .kv-pdp-ft-swiper {
        overflow: hidden;
}

}

@media (max-width: 991.98px) {
    .kv-pdp-ft-tabs-row {
        flex-direction: column;
        align-items: flex-start;
    }

    .swiper.kv-pdp-ft-swiper {
        margin: 0 -20px;
        padding: 0 20px;
    }
    .kv-pdp-ft-cta {
    display: none;
}

.kv-pdp-ft-cta.mobile-cta {
    display: flex !important;
    justify-content: center;
    max-width: 390px;
    margin: 36px auto 0;
}

.kv-pdp-ft-tab {
    font-size: 16px;
    white-space: nowrap;
}

.kv-pdp-ft-tabs {
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    flex-wrap: nowrap;
    scrollbar-width: none;
    max-width: 100%;
    width: 100%;
}

.kv-pdp-ft-tabs::-webkit-scrollbar {
    display: none;
}

.kv-pdp-ft-tab {
    scroll-snap-align: start;
    flex-shrink: 0;
}

}

@media (max-width: 767.98px) {

    .kv-pdp-ft-header {
    padding: 0 0 36px 0;
}

.kv-pdp-ft-tabs-row {
    margin-bottom: 36px;
}

.kv-pdp-ft-progressbar-wrap {
    margin-top: 36px;
}

.kv-pdp-ft-card-title {
    font-size: 18px;
}


}

@media (max-width: 639px) {
    .kv-pdp-ft-header .kv-font-42 {
    margin: 0 0 12px 0;
}

}
</style>
