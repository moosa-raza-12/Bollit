{% liquid
  assign section_id = section.id | prepend: 'kv-team-' 
%}

<style>
  .kv-our-team {
    background: {{ section.settings.bg_color }};
  }

  .kv-our-team-header {
    text-align: center;
    max-width: 860px;
    margin: 0 auto 28px;
  }

 

  .kv-our-team-subtitle {
    margin: 0;
    color: rgba(31, 31, 31, 0.70);
    text-align: center;
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 150%;
  }

  .kv-our-team-swiper {
    padding-bottom: 0px;
  }

  .kv-our-team-card {
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.50);
    display: flex;
    padding: 16px;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 0px;
  }

.kv-our-team-image-wrap {
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 24px;
    aspect-ratio: 1 / 1;
}
.kv-our-team-image-wrap img {
    width: 100%;
    display: block;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    height: 100%;
}

  .kv-our-team-name {
    color: #1F1F1F;
    text-align: center;
    font-size: 24px;
    font-style: normal;
    font-weight: 500;
    line-height: 120%;
    margin: 0;
  }

  .kv-our-team-role {
    color: rgba(31, 31, 31, 0.80);
    text-align: center;
    font-size: 20px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    padding-top: 16px;
    margin: 0;
    padding: 0;
    opacity: 0.6;
  }


  .kv-our-team .swiper-scrollbar  {
  position: relative;
  height: 3px;
  background-color: #e5e7eb;
  border-radius: 16px;
  margin-top: 70px;
  overflow: hidden;
}

.kv-our-team .kv-team-scrollbar-fill {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  width: 0%;
  background: #003665;
  border-radius: 16px;
  pointer-events: none;
  z-index: 1;
}

.swiper-scrollbar-drag{
  display: block ;
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  min-width: auto;
  background: rgba(0, 54, 101, 0.25);
  border-radius: 16px;
  opacity: 1;
  transition: width 0.3s ease-out;
  z-index: 2;
}


    .kv-our-team .swiper-slide {
        width: 300px;
    }
    .swiper.kv-our-team-swiper {
        overflow: visible;
}
.kv-section.kv-our-team {
    overflow: hidden;
}
  @media (max-width: 767px) {
.kv-our-team-subtitle {
    font-size: 14px;
}
.kv-our-team-name {
    font-size: 22px;
}
.kv-our-team-role {
    font-size: 18px;
}
.kv-our-team .swiper-scrollbar {
    margin-top: 36px;
}
  }
</style>

<section class="kv-section kv-our-team" id="{{ section_id }}">
  <div class="kv-custom-container">
    <div class="kv-section-head">
      {% if section.settings.label != blank %}
        <span>{{ section.settings.label }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="kv-font-38">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subtitle != blank %}
        <p class="kv-our-team-subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>

    <div class="swiper kv-our-team-swiper">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          <div class="swiper-slide" {{ block.shopify_attributes }}>
            <div class="kv-our-team-card">
              {% if block.settings.image != blank %}
                <div class="kv-our-team-image-wrap">
                  {{
                    block.settings.image
                    | image_url: width: 700
                    | image_tag:
                      loading: 'lazy',
                      widths: '260, 360, 520, 700',
                      sizes: '(max-width: 767px) 70vw, (max-width: 991px) 35vw, 22vw',
                      alt: block.settings.name
                  }}
                </div>
              {% endif %}
              {% if block.settings.name != blank %}
                <h3 class="kv-our-team-name">{{ block.settings.name }}</h3>
              {% endif %}
              {% if block.settings.role != blank %}
                <p class="kv-our-team-role">{{ block.settings.role }}</p>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
      <div class="swiper-scrollbar"></div>
    </div>
  </div>
</section>


<script>
  (function () {
    var sectionEl = document.getElementById('{{ section_id }}');
    if (!sectionEl) return;

    function initTeamSwiper() {
      if (typeof Swiper === 'undefined') return false;
      var swiperEl = sectionEl.querySelector('.kv-our-team-swiper');
      if (!swiperEl || swiperEl.classList.contains('swiper-initialized')) return true;

      var swiperInstance = new Swiper(swiperEl, {
        speed: 550,
        grabCursor: true,
        watchOverflow: false,
        slidesPerView: 'auto',
        spaceBetween: 16,
        freeMode: {
            enabled: true,
            momentum: true
        },

        scrollbar: {
          el: sectionEl.querySelector('.swiper-scrollbar'),
          draggable: true,
          hide: false
        },
        breakpoints: {
          576: {
            slidesPerView:'auto',
            spaceBetween: 16
          },
          768: {
            slidesPerView: 'auto',
            spaceBetween: 18
          },
          992: {
            slidesPerView: 'auto',
            spaceBetween: 18
          }
        }
      });

      var scrollbarEl = sectionEl.querySelector('.swiper-scrollbar');
      if (scrollbarEl && !scrollbarEl.querySelector('.kv-team-scrollbar-fill')) {
        var fillEl = document.createElement('span');
        fillEl.className = 'kv-team-scrollbar-fill';
        scrollbarEl.insertBefore(fillEl, scrollbarEl.firstChild);

        var updateFill = function () {
          var progress = Math.max(0, Math.min(1, swiperInstance.progress || 0));
          fillEl.style.width = (progress * 100) + '%';
        };

        swiperInstance.on('init', updateFill);
        swiperInstance.on('setTranslate', updateFill);
        swiperInstance.on('slideChange', updateFill);
        swiperInstance.on('resize', updateFill);
        updateFill();
      }

      return true;
    }

    if (!initTeamSwiper()) {
      var tries = 0;
      var poll = setInterval(function () {
        tries += 1;
        if (initTeamSwiper() || tries > 40) clearInterval(poll);
      }, 100);
    }
  })();
</script>

{% schema %}
{
  "name": "KV Our Team",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "BG Color",
      "default": "#F0F8FF"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Top label",
      "default": "Behind the scenes"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Our <em>team</em>"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "The people behind Bollit share one goal, creating cleaning tools that make everyday life easier."
    }
  ],
  "blocks": [
    {
      "type": "member",
      "name": "Team member",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Member image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Name"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role",
          "default": "Role"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "KV Our Team",
      "blocks": [
        {
          "type": "member",
          "settings": {
            "name": "Name",
            "role": "Role"
          }
        },
        {
          "type": "member",
          "settings": {
            "name": "Name",
            "role": "Role"
          }
        },
        {
          "type": "member",
          "settings": {
            "name": "Name",
            "role": "Role"
          }
        },
        {
          "type": "member",
          "settings": {
            "name": "Name",
            "role": "Role"
          }
        }
      ]
    }
  ]
}
{% endschema %}
