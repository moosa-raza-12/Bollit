              <a href="{{ block.settings.url }}" class="lp-header__nav-link">
                {{ block.settings.text }}
                {%- if block.settings.has_dropdown -%}
                  <svg width="10" height="5" viewBox="0 0 10 5" fill="none">
                    <path d="M1 1L5 4L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                {%- endif -%}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </nav>
      <div class="lp-header__actions">
