{%- comment -%}
  Mobile-only horizontal “best sellers” chips: lead pill + product pills with optional title/image overrides.
{%- endcomment -%}

{%- assign lead_label = section.settings.lead_label | default: 'Popular' -%}

{%- if lead_label != blank or section.blocks.size > 0 -%}
  <div class="kv-best-sellers" id="kv-best-sellers-{{ section.id }}">
    <div class="kv-best-sellers__track" role="list">
      {%- if lead_label != blank -%}
        <div class="kv-best-sellers__chip kv-best-sellers__chip--lead" role="listitem">
          {%- if section.settings.lead_link != blank -%}
            <a href="{{ section.settings.lead_link }}" class="kv-best-sellers__lead-inner">
              {{- lead_label -}}
            </a>
          {%- else -%}
            <span class="kv-best-sellers__lead-inner">{{ lead_label }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- if block.type == 'product_chip' and block.settings.product != blank -%}
          {%- assign p = block.settings.product -%}
          {%- liquid
            assign chip_title = block.settings.title
            if chip_title == blank
              assign chip_title = p.title
            endif
            assign chip_image = block.settings.image
          -%}
          <div class="kv-best-sellers__chip kv-best-sellers__chip--product" role="listitem" {{ block.shopify_attributes }}>
            <a href="{{ p.url }}" class="kv-best-sellers__product-link">
              <span class="kv-best-sellers__img-wrap">
                {%- if chip_image != blank -%}
                  <img
                    src="{{ chip_image | image_url: width: 96 }}"
                    alt="{{ chip_title | escape }}"
                    width="32"
                    height="32"
                    loading="lazy"
                  >
                {%- elsif p.featured_image != blank -%}
                  <img
                    src="{{ p.featured_image | image_url: width: 96 }}"
                    alt="{{ chip_title | escape }}"
                    width="32"
                    height="32"
                    loading="lazy"
                  >
                {%- else -%}
                  <span class="kv-best-sellers__img-placeholder" aria-hidden="true"></span>
                {%- endif -%}
              </span>
              <span class="kv-best-sellers__label">{{ chip_title }}</span>
            </a>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <style>
    #kv-best-sellers-{{ section.id }} {
      --kv-bs-lead-bg: {{ section.settings.lead_background }};
      --kv-bs-lead-fg: {{ section.settings.lead_text_color }};
      --kv-bs-chip-bg: {{ section.settings.chip_background }};
      --kv-bs-chip-border: {{ section.settings.chip_border }};
      --kv-bs-label: {{ section.settings.chip_label_color }};
      --kv-bs-ring: {{ section.settings.image_ring_color }};
      --kv-bs-page-bg: {{ section.settings.section_background }};
      display: none;
      width: 100%;
      padding: 12px 0;
      background: var(--kv-bs-page-bg, #f5f5f5);
    }
    @media screen and (max-width: 749.98px) {
      #kv-best-sellers-{{ section.id }} {
        display: block;
      }
    }
    .shopify-design-mode #kv-best-sellers-{{ section.id }} {
      display: block !important;
    }
    #kv-best-sellers-{{ section.id }} .kv-best-sellers__track {
      display: flex;
      flex-wrap: nowrap;
      align-items: center;
      gap: 8px;
      margin: 0;
      padding: 0 16px;
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      list-style: none;
    }
    #kv-best-sellers-{{ section.id }} .kv-best-sellers__track::-webkit-scrollbar {
      display: none;
    }
    #kv-best-sellers-{{ section.id }} .kv-best-sellers__chip {
      flex: 0 0 auto;
    }
    #kv-best-sellers-{{ section.id }} .kv-best-sellers__chip--lead {
      border-radius: 999px;
      background: var(--kv-bs-lead-bg, #1e2a4a);
      color: var(--kv-bs-lead-fg, #ffffff);
      font-size: 14px;
      font-weight: 600;
      line-height: 1.2;
      white-space: nowrap;
    }
    #kv-best-sellers-{{ section.id }} .kv-best-sellers__lead-inner {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 40px;
      padding: 0 18px;
      color: inherit;
      text-decoration: none;
    }
    #kv-best-sellers-{{ section.id }} a.kv-best-sellers__lead-inner {
      color: inherit;
    }
    #kv-best-sellers-{{ section.id }} .kv-best-sellers__chip--product {
      border-radius: 999px;
      border: 1px solid var(--kv-bs-chip-border, #e5e5e5);
      background: var(--kv-bs-chip-bg, #ffffff);
    }
    #kv-best-sellers-{{ section.id }} .kv-best-sellers__product-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      min-height: 40px;
      padding: 4px 14px 4px 6px;
      text-decoration: none;
      color: var(--kv-bs-label, #1e2a4a);
      font-size: 14px;
      font-weight: 600;
      line-height: 1.2;
      white-space: nowrap;
    }
    #kv-best-sellers-{{ section.id }} .kv-best-sellers__img-wrap {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      flex-shrink: 0;
      border-radius: 50%;
      border: 1px solid var(--kv-bs-ring, #93c5fd);
      overflow: hidden;
      background: #fff;
    }
    #kv-best-sellers-{{ section.id }} .kv-best-sellers__img-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    #kv-best-sellers-{{ section.id }} .kv-best-sellers__img-placeholder {
      display: block;
      width: 100%;
      height: 100%;
      background: #e8e8e8;
    }
    #kv-best-sellers-{{ section.id }} .kv-best-sellers__label {
      max-width: 42vw;
      overflow: hidden;
      text-overflow: ellipsis;
    }
  </style>
{%- endif -%}

{% schema %}
{
  "name": "KV PDP Best sellers",
  "tag": "section",
  "class": "kv-pdp-best-sellers-section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Lead pill"
    },
    {
      "type": "text",
      "id": "lead_label",
      "label": "Lead label",
      "default": "Popular"
    },
    {
      "type": "url",
      "id": "lead_link",
      "label": "Lead link",
      "info": "Optional. Leave empty to show text only."
    },
    {
      "type": "color",
      "id": "lead_background",
      "label": "Lead background",
      "default": "#1e2a4a"
    },
    {
      "type": "color",
      "id": "lead_text_color",
      "label": "Lead text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Product chips"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Bar background",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "chip_background",
      "label": "Chip background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "chip_border",
      "label": "Chip border",
      "default": "#e5e5e5"
    },
    {
      "type": "color",
      "id": "chip_label_color",
      "label": "Product title color",
      "default": "#1e2a4a"
    },
    {
      "type": "color",
      "id": "image_ring_color",
      "label": "Image ring",
      "default": "#93c5fd"
    }
  ],
  "blocks": [
    {
      "type": "product_chip",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "info": "Optional. Falls back to the product title."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Optional. Falls back to the product featured image."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "KV PDP Best sellers",
      "blocks": [
        {
          "type": "product_chip"
        },
        {
          "type": "product_chip"
        }
      ]
    }
  ]
}
{% endschema %}
