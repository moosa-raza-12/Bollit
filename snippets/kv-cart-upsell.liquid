<div class="kv-cart-upsell">
    {% if settings.cart_product_upsell_heading != blank %}
        <h4>{{ settings.cart_product_upsell_heading }}</h4>
    {% endif %}
    <div class="kv-cart-upsell-slider-outer">
        <div class="swiper kv-cart-upsell-slider">
            <div class="swiper-wrapper">
                {% if settings.cart_product_upsell != blank %}
                    {% for upsell_product in settings.cart_product_upsell %}
                        <div class="swiper-slide">
                            <div class="kv-cart-upsell-item">
                                {% if upsell_product.featured_image %}
                                    <a href="{{ upsell_product.url }}" class="kv-cart-upsell-item__image-link">
                                        <img
                                            class="kv-cart-upsell-item__image"
                                            src="{{ upsell_product.featured_image | image_url: width: 500 }}"
                                            alt="{{ upsell_product.featured_image.alt | default: upsell_product.title | escape }}"
                                            loading="lazy"
                                            width="250"
                                            height="{{ 250 | divided_by: upsell_product.featured_image.aspect_ratio | ceil }}"
                                        >
                                    </a>
                                {% endif %}

                                <div class="kv-cart-upsell-item__content">
                                    <a href="{{ upsell_product.url }}" class="kv-cart-upsell-item__title">
                                        {{ upsell_product.title | escape }}
                                    </a>
                                    {% assign upsell_description = upsell_product.metafields.custom.cart_line_item_description %}
                                    {% if upsell_description != blank %}
                                        <div class="kv-cart-upsell-item__description">
                                            {{ upsell_description.value }}
                                        </div>
                                    {% endif %}
                                    <div class="kv-cart-upsell-item__price">
                                        {{ upsell_product.price | money }}
                                    </div>
                                  
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}

            </div>

            <!-- Progress bar -->
            <div class="swiper-pagination"></div>
            </div>

    </div>
</div>

<style>
.kv-cart-upsell {
    background: #F8F8F6;
    padding: 24px 20px;
    flex-direction: column;
    justify-content: center;
    gap: 24px;
    display: flex;
}
.kv-cart-upsell h4 {
    color: #1F1F1F;
    font-size: 20px;
    font-style: normal;
    font-weight: 500;
    line-height: 120%;
    letter-spacing: -0.3px;
    margin: 0;
}

.kv-cart-upsell .swiper-slide{
    border-radius: 20px;
    background: #FFF;
    padding: 20px;
    box-sizing: border-box;
}
.kv-cart-upsell-item {
    display: flex;
    align-items: center;
    gap: 12px;
}
a.kv-cart-upsell-item__image-link {
    border-radius: 13.5px;
    background: #F8F8F6;
    width: 70px;
    height: 70px;
    overflow: hidden;
}
a.kv-cart-upsell-item__image-link img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

a.kv-cart-upsell-item__title {
    color: #1F1F1F;
    font-size: 16px;
    font-style: normal;
    font-weight: 500;
    line-height: 120%;
    text-decoration: none;
    display: block;
}

.kv-cart-upsell-item__price {
    color: #1F1F1F;
    font-size: 16px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
}
.kv-cart-upsell .swiper-pagination.swiper-pagination-progressbar {
    border-radius: 16px;
    background: rgba(204, 204, 204, 0.40);
    height: 3px;
    top: auto;
    bottom: 0;
}
.kv-cart-upsell span.swiper-pagination-progressbar-fill {
    border-radius: 16px;
    background: #003665;
}
.kv-cart-upsell-slider-outer .swiper-wrapper {
    padding-bottom: 27px;
}
.kv-cart-upsell .kv-cart-upsell-slider{
    padding: 0px 20px;
    margin: 0px -20px;
}
.kv-cart-upsell-item__description {
    color: #063030;
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 120%;
    opacity: 0.6;
    letter-spacing: 0;
    padding: 2px 0px 3px 0px;
}
</style>
<script>
(function () {
  function initCartUpsellSwiper(root) {
    if (typeof Swiper === "undefined") return;

    var scope = root || document;
    var sliders = scope.querySelectorAll(".kv-cart-upsell-slider");
    if (!sliders.length) return;

    sliders.forEach(function (sliderEl) {
      if (sliderEl.classList.contains("swiper-initialized")) return;

      var container = sliderEl.closest(".kv-cart-upsell");
      var paginationEl = container ? container.querySelector(".swiper-pagination") : null;

      new Swiper(sliderEl, {
        slidesPerView: 1.3,
        spaceBetween: 12,
        loop: false,
        pagination: {
          el: paginationEl,
          type: "progressbar",
        },
        breakpoints: {
          768: {
            slidesPerView: 1.3,
          },
          1024: {
            slidesPerView: 1.3,
          },
        },
      });
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", function () {
      initCartUpsellSwiper(document);
    });
  } else {
    initCartUpsellSwiper(document);
  }

  var cartDrawer = document.querySelector("cart-drawer");
  if (cartDrawer && !cartDrawer.dataset.kvUpsellObserverAttached) {
    cartDrawer.dataset.kvUpsellObserverAttached = "true";

    var observer = new MutationObserver(function (mutations) {
      mutations.forEach(function (mutation) {
        if (!mutation.addedNodes || !mutation.addedNodes.length) return;
        mutation.addedNodes.forEach(function (node) {
          if (!(node instanceof Element)) return;
          if (node.matches(".kv-cart-upsell") || node.querySelector(".kv-cart-upsell")) {
            initCartUpsellSwiper(node);
          }
        });
      });
    });

    observer.observe(cartDrawer, { childList: true, subtree: true });
  }
})();
</script>